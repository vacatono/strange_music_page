---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home">
  <div class="portal-container">
    <h1 class="page-title">strange music page</h1>
    <p class="page-subtitle">(live memo archive)</p>
    
    <div class="portal-grid">
      <a href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/live/`} class="portal-card">
  
        <div class="portal-card-content">
          <h2 class="portal-card-title">Live Memo</h2>
          <p class="portal-card-desc">ライブの備忘録・セットリストアーカイブ (1993-)</p>
        </div>
      </a>
      

    </div>
  </div>

  <style>
    .portal-container {
      padding: 2rem 0;
      text-align: center;
    }
    .portal-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.5rem;
      margin-top: 3rem;
    }
    .portal-card {
      display: flex;
      align-items: center;
      gap: 1.5rem;
      padding: 2rem;
      background: var(--color-bg-card);
      border: 1px solid var(--color-border);
      border-radius: var(--radius);
      text-decoration: none;
      color: inherit;
      transition: all 0.3s ease;
      text-align: left;
    }
    .portal-card:not(.disabled):hover {
      transform: translateY(-5px);
      border-color: var(--color-accent);
      box-shadow: 0 10px 20px rgba(0,0,0,0.05);
    }
    .portal-card.disabled {
      opacity: 0.6;
      cursor: not-allowed;
    }
    .portal-card-icon {
      font-size: 3rem;
    }
    .portal-card-title {
      margin: 0 0 0.5rem 0;
      font-size: 1.5rem;
      color: var(--color-text-heading);
    }
    .portal-card-desc {
      margin: 0;
      font-size: 0.9rem;
      color: var(--color-text-muted);
    }
  </style>
</BaseLayout>
