---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { toSlug } from '../../../utils/slug';

export async function getStaticPaths() {
  const reports = await getCollection('livereports');
  return reports.map(report => ({
    params: { slug: report.id },
    props: { report },
  }));
}

const { report } = Astro.props;
const { Content } = await render(report);

const dateStr = report.data.date ? report.data.date.toISOString().slice(0, 10) : '日付不明';
const year = report.data.date ? report.data.date.getFullYear() : '不明';
const title = report.data.title || '無題';
---

<BaseLayout title={title} description={`${dateStr} ${title} - live memo`}>
  <a href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/live/years/${year}/`} class="back-link">← {year}年のメモへ</a>

  <article>
    <div class="report-header">
      <h1 class="page-title">{title}</h1>
      <div class="report-meta">
        <span class="report-meta-item">📅 {dateStr}</span>
        {report.data.venue && (
          <span class="report-meta-item">📍 <a href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/live/venues/${toSlug(report.data.venue)}/`}>{report.data.venue}</a></span>
        )}
      </div>

      {report.data.artists && report.data.artists.length > 0 && (
        <div style="margin-top: 0.75rem;">
          <ul class="tag-list">
            {report.data.artists.map((artist: string) => (
              <li>
                <a href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/live/artists/${toSlug(artist)}/`} class="tag-link">{artist}</a>
              </li>
            ))}
          </ul>
        </div>
      )}
    </div>

    <div class="report-body">
      <Content />
    </div>

    {report.data.setlist && report.data.setlist.length > 0 && (
      <div class="report-body">
        <h2>セットリスト</h2>
        <ol>
          {report.data.setlist.map((song: string) => (
            <li>{song}</li>
          ))}
        </ol>
      </div>
    )}
  </article>
</BaseLayout>
