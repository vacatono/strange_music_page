---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const reports = await getCollection('livereports');

  const years = new Set<number>();
  for (const r of reports) {
    if (r.data.date) {
      years.add(r.data.date.getFullYear());
    }
  }

  return [...years].map(year => ({
    params: { year: String(year) },
    props: {
      year,
      reports: reports
        .filter(r => r.data.date && r.data.date.getFullYear() === year)
        .sort((a, b) => (a.data.date?.getTime() || 0) - (b.data.date?.getTime() || 0)),
    },
  }));
}

const { year, reports } = Astro.props;
---

<BaseLayout title={`${year}年のライブメモ`}>
  <a href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/live/years/`} class="back-link">← 年別一覧へ</a>
  <h1 class="page-title">{year}年</h1>
  <p class="page-subtitle">{reports.length}件のメモ</p>

  {reports.map((report: any) => (
    <a href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/live/report/${report.id}/`} class="report-card">
      <div class="report-card-date">
        {report.data.date.toISOString().slice(0, 10)}
      </div>
      <div class="report-card-title">{report.data.title}</div>
      {report.data.venue && (
        <div class="report-card-venue">{report.data.venue}</div>
      )}
    </a>
  ))}
</BaseLayout>
