---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { toSlug } from '../../utils/slug';

const reports = await getCollection('livereports');

// アーティスト別集計
const artistCounts = new Map<string, number>();
for (const r of reports) {
  for (const artist of (r.data.artists || [])) {
    artistCounts.set(artist, (artistCounts.get(artist) || 0) + 1);
  }
}

const artists = [...artistCounts.entries()]
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));
---

<BaseLayout title="アーティスト一覧">
  <a href="/" class="back-link">← トップへ</a>
  <h1 class="page-title">アーティスト一覧</h1>
  <p class="page-subtitle">{artists.length}名のアーティスト</p>

  <ul class="tag-list">
    {artists.map(([name, count]) => (
      <li>
        <a href={`/artists/${toSlug(name)}/`} class="tag-link">
          {name}<span class="tag-count">({count})</span>
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>
